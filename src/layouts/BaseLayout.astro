---
import { siteLinks } from '../data/resources';

const {
  title = 'AI Steering Files',
  description = 'A practical catalog of repository steering files, agent instructions, and project context docs.',
  canonicalPath,
  robots,
  structuredData = [],
  ogType = 'website'
} = Astro.props;

const siteUrl = Astro.site ?? new URL(siteLinks.site);
const plausibleDomain =
  import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN ?? (import.meta.env.PROD ? new URL(siteLinks.site).hostname : '');
const siteRoot = new URL('/', siteUrl).toString();
const canonicalUrl =
  canonicalPath === false ? null : new URL(canonicalPath ?? Astro.url.pathname, siteUrl).toString();
const pageUrl = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const structuredDataItems = Array.isArray(structuredData) ? structuredData : [structuredData].filter(Boolean);
const baseStructuredData = canonicalUrl
  ? [
      {
        '@type': 'WebSite',
        '@id': `${siteRoot}#website`,
        url: siteRoot,
        name: 'AI Steering Files',
        description: 'A practical catalog of repo context files and agent instructions for AI coding agents.',
        inLanguage: 'en'
      },
      {
        '@type': 'WebPage',
        '@id': `${pageUrl}#webpage`,
        url: pageUrl,
        name: title,
        description,
        isPartOf: {
          '@id': `${siteRoot}#website`
        },
        inLanguage: 'en'
      }
    ]
  : [];
const schemaGraph = [...baseStructuredData, ...structuredDataItems];
const schema =
  schemaGraph.length > 0
    ? {
        '@context': 'https://schema.org',
        '@graph': schemaGraph
      }
    : null;
const schemaJson = schema
  ? JSON.stringify(schema)
      .replace(/</g, '\\u003c')
      .replace(/>/g, '\\u003e')
      .replace(/&/g, '\\u0026')
  : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="AI Steering Files" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {
      plausibleDomain && (
        <>
          <script is:inline>
            window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }
          </script>
          <script
            is:inline
            defer
            data-domain={plausibleDomain}
            src="https://plausible-v2.cr.lvtd.dev/js/script.file-downloads.hash.outbound-links.js"
          ></script>
        </>
      )
    }
    {schemaJson && <script is:inline type="application/ld+json" set:html={schemaJson} />}
    <style is:global>
      :root {
        color-scheme: light;
        --bg: oklch(96.8% 0.004 260);
        --surface: oklch(99.4% 0.002 260);
        --surface-muted: oklch(93.6% 0.006 260);
        --ink: oklch(17.5% 0.02 250);
        --muted: oklch(42% 0.035 246);
        --subtle: oklch(55% 0.025 246);
        --line: oklch(84.5% 0.012 252);
        --line-strong: oklch(72% 0.018 252);
        --accent: oklch(45% 0.13 24);
        --accent-hover: oklch(38% 0.135 24);
        --accent-soft: oklch(93.5% 0.035 24);
        --accent-ink: oklch(98.5% 0.004 24);
        --focus: oklch(55% 0.16 250);
        --radius-sm: 6px;
        --radius-md: 10px;
        --z-sticky: 10;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * { box-sizing: border-box; }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--ink);
        font-size: 16px;
        line-height: 1.5;
        text-rendering: optimizeLegibility;
      }

      body::selection {
        background: var(--accent-soft);
      }

      a {
        color: inherit;
        text-underline-offset: 0.18em;
      }

      a:focus-visible,
      button:focus-visible {
        outline: 3px solid var(--focus);
        outline-offset: 3px;
      }

      code {
        border-radius: 4px;
        background: var(--surface-muted);
        color: var(--accent);
        font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
        font-size: 0.92em;
        font-weight: 600;
        padding: 0.08rem 0.25rem;
        word-break: break-word;
      }

      .container {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
      }

      .skip-link {
        position: fixed;
        top: 0.75rem;
        left: 0.75rem;
        z-index: calc(var(--z-sticky) + 1);
        transform: translateY(-150%);
        border-radius: var(--radius-sm);
        background: var(--ink);
        color: #fff;
        font-weight: 700;
        padding: 0.65rem 0.8rem;
        text-decoration: none;
        transition: transform 180ms ease-out;
      }

      .skip-link:focus-visible {
        transform: translateY(0);
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: var(--z-sticky);
        border-bottom: 1px solid var(--line);
        background: var(--bg);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.75rem 0;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        color: var(--ink);
        font-weight: 700;
        text-decoration: none;
      }

      .brand-logo {
        display: block;
        width: 34px;
        height: 34px;
        flex: 0 0 auto;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        color: var(--muted);
        font-size: 0.92rem;
        font-weight: 600;
      }

      .nav-links a {
        border-radius: var(--radius-sm);
        text-decoration: none;
      }

      .nav-links a:hover {
        color: var(--ink);
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        padding: 0.62rem 0.82rem;
        border: 1px solid transparent;
        border-radius: var(--radius-sm);
        background: var(--accent);
        color: var(--accent-ink);
        font-weight: 700;
        text-decoration: none;
        transition:
          background-color 180ms ease-out,
          border-color 180ms ease-out,
          color 180ms ease-out;
      }

      .button:hover {
        background: var(--accent-hover);
      }

      .button.secondary {
        border-color: var(--line);
        background: var(--surface);
        color: var(--ink);
      }

      .button.secondary:hover {
        border-color: var(--line-strong);
        background: var(--surface-muted);
      }

      .section-label {
        margin: 0 0 0.55rem;
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 700;
      }

      .section {
        padding: 3.5rem 0;
        border-top: 1px solid var(--line);
      }

      .section h2 {
        margin: 0;
        max-width: 820px;
        font-size: 2rem;
        line-height: 1.12;
        letter-spacing: -0.02em;
        text-wrap: balance;
      }

      .section-lede {
        max-width: 760px;
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.65;
        text-wrap: pretty;
      }

      .page-header {
        padding: 3.3rem 0 2.4rem;
      }

      .page-header-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(280px, 0.45fr);
        gap: 2rem;
        align-items: start;
      }

      .page-header h1 {
        margin: 0;
        max-width: 820px;
        font-size: 3rem;
        line-height: 1.05;
        letter-spacing: -0.025em;
        text-wrap: balance;
      }

      .lede {
        max-width: 720px;
        margin: 1rem 0 0;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.65;
        text-wrap: pretty;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
        margin-top: 1.35rem;
      }

      .info-panel,
      .content-panel {
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: var(--surface);
        padding: 1rem;
      }

      .info-panel h2,
      .content-panel h3 {
        margin: 0 0 0.7rem;
        font-size: 0.98rem;
        line-height: 1.35;
        letter-spacing: 0;
      }

      .plain-list {
        margin: 0;
        padding-left: 1.1rem;
        color: var(--muted);
        line-height: 1.65;
      }

      .plain-list li + li {
        margin-top: 0.45rem;
      }

      .split-layout {
        display: grid;
        grid-template-columns: minmax(0, 0.58fr) minmax(0, 1fr);
        gap: 2rem;
        align-items: start;
      }

      .footer {
        border-top: 1px solid var(--line);
        color: var(--muted);
        padding: 1.5rem 0;
        font-size: 0.92rem;
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          scroll-behavior: auto !important;
          transition-duration: 0.01ms !important;
        }
      }

      @media (max-width: 760px) {
        .container { width: min(100% - 24px, 1180px); }
        .nav-inner { align-items: flex-start; flex-direction: column; }
        .nav-links { flex-wrap: wrap; gap: 0.75rem; }
        .nav-links .button { width: auto; }
        .section { padding: 2.7rem 0; }
        .page-header { padding: 2.4rem 0 2rem; }
        .page-header-grid,
        .split-layout {
          grid-template-columns: 1fr;
        }
        .page-header h1 {
          font-size: 2.35rem;
        }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <nav class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/" aria-label="AI Steering Files home">
          <img class="brand-logo" src="/logo.svg" alt="" width="40" height="40" />
          <span>AI Steering Files</span>
        </a>
        <div class="nav-links">
          <a href="/#install-skill">Skill</a>
          <a href="/#catalog">Catalog</a>
          <a href="/#checklist">Checklist</a>
          <a href="/contributing/">Contribute</a>
          <a class="button secondary" href={siteLinks.readme}>README</a>
          <a class="button secondary" href={siteLinks.repo}>GitHub repo</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="footer">
      <div class="container">A practical index for repo context files that keep coding agents aligned with your project.</div>
    </footer>
  </body>
</html>
