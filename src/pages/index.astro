---
import BaseLayout from '../layouts/BaseLayout.astro';
import { installableSkill, sections, siteLinks } from '../data/resources';
import { slugify } from '../lib/slugify.js';
---

<BaseLayout title="AI Steering Files - repo context for coding agents" description="A shared guide to the files that teach AI agents how to work in this repo.">
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Repository guidance</p>
          <h1>AI steering files for real projects.</h1>
          <p class="lede">
            A clean index of the repo context files that help agents make better edits, avoid dead ends, and keep implementation choices aligned with the project.
          </p>
          <div class="actions">
            <a class="button" href="#install-skill">Install the skill</a>
            <a class="button" href="#catalog">Browse the files</a>
            <a class="button secondary" href={siteLinks.readme}>Open the README</a>
            <a class="button secondary" href="/contributing/">Suggest a site</a>
            <a class="button secondary" href={siteLinks.repo}>Open the repo</a>
          </div>
        </div>
        <aside class="hero-note" aria-label="How to use this site">
          <p class="eyebrow">How to use it</p>
          <ul>
            <li>Start with the agent-agnostic files when you need repo rules that apply everywhere.</li>
            <li>Use the agent-specific files when a tool needs its own memory, syntax, or workflow hints.</li>
            <li>Keep the guidance grounded in real commands, constraints, and examples.</li>
          </ul>
        </aside>
      </div>
    </section>

    <section id="install-skill" class="section install-section">
      <div class="container install-grid">
        <div>
          <p class="eyebrow">Reusable skill</p>
          <h2>Install the catalog as an agent skill.</h2>
          <p class="section-lede">
            The <code>{installableSkill.name}</code> skill gives agents a compact workflow for choosing, writing, and auditing repo context files in any project.
          </p>
          <a class="button secondary" href={siteLinks.skill}>View skill source</a>
        </div>

        <div class="install-panel" aria-label="Skill installation commands">
          <div>
            <h3>Skills CLI</h3>
            <pre><code>{installableSkill.skillsCliCommand}</code></pre>
            <a href={siteLinks.skillsCli}>Skills CLI docs</a>
          </div>

          <div>
            <h3>GitHub CLI</h3>
            <pre><code>{installableSkill.githubCliCommand}</code></pre>
            <a href={siteLinks.ghSkill}>gh skill install docs</a>
          </div>
        </div>
      </div>
    </section>

    <section id="catalog" class="section">
      <div class="container catalog-shell">
        <div class="catalog-content">
          {sections.map((section) => (
            <section class="resource-group" id={section.slug}>
              <div class="section-heading">
                <p class="eyebrow">{section.title}</p>
                <h2>{section.title}</h2>
                <p class="section-lede">{section.intro}</p>
              </div>

              <div class="resource-grid">
                {section.resources.map((resource) => (
                  <article class="resource-card" id={slugify(resource.name)}>
                    <div class="resource-summary">
                      <p class="path"><code>{resource.path}</code></p>
                      <h3>{resource.name}</h3>
                      <p class="summary">{resource.summary}</p>
                      <p class="best"><strong>Use it for:</strong> {resource.useItFor.join(', ')}</p>
                    </div>

                    <div class="resource-details">
                      <div>
                        <h4>Should contain</h4>
                        <ul>
                          {resource.shouldContain.map((item) => <li>{item}</li>)}
                        </ul>
                      </div>

                      <div class="links-grid">
                        <div>
                          <h4>Useful resources</h4>
                          <ul class="link-list">
                            {resource.usefulResources.map((link) => (
                              <li><a href={link.href}>{link.label}</a></li>
                            ))}
                          </ul>
                        </div>

                        <div>
                          <h4>Great examples</h4>
                          <ul class="link-list">
                            {resource.greatExamples.map((link) => (
                              <li><a href={link.href}>{link.label}</a></li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section id="checklist" class="section">
      <div class="container checklist-wrap">
        <div>
          <p class="eyebrow">Writing checklist</p>
          <h2>Good steering files are short, specific, and grounded in the repo.</h2>
        </div>
        <ol class="checklist">
          <li><strong>Say what the file controls.</strong> Start with the scope and the intended reader.</li>
          <li><strong>Prefer commands over vibes.</strong> Include exact install, test, lint, build, and deploy commands.</li>
          <li><strong>Name the good examples.</strong> Point agents to files and modules that show the preferred pattern.</li>
          <li><strong>Document constraints.</strong> Spell out security, data, accessibility, performance, and product boundaries.</li>
          <li><strong>Keep the source shared.</strong> Edit the data map once, then render the site and README from it.</li>
          <li><strong>Review after real agent work.</strong> Update the files when agents repeatedly ask the same question or make the same mistake.</li>
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    padding: 5.5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 1.5rem;
    align-items: start;
  }

  .hero-copy {
    padding: 0.25rem 0;
  }

  h1 {
    margin: 0;
    max-width: 880px;
    font-size: clamp(3rem, 7vw, 6.3rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
  }

  .lede {
    max-width: 680px;
    margin-top: 1.2rem;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.35vw, 1.15rem);
    line-height: 1.68;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  .hero-note {
    padding: 1.4rem 1.35rem;
    border: 1px solid var(--line);
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.78)),
      radial-gradient(circle at top right, rgba(91, 192, 190, 0.18), transparent 45%);
    box-shadow: var(--shadow);
  }

  .hero-note ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.75;
  }

  .catalog-shell {
    display: grid;
    gap: 0;
  }

  .install-section {
    background: rgba(255, 255, 255, 0.28);
  }

  .install-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(340px, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .install-panel {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--panel);
    box-shadow: 0 10px 28px rgba(16, 24, 32, 0.04);
  }

  .install-panel h3 {
    margin: 0 0 0.55rem;
    font-size: 1rem;
  }

  .install-panel pre {
    overflow-x: auto;
    margin: 0;
    padding: 0.95rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: #10131a;
    color: #fff;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .install-panel a {
    display: inline-block;
    margin-top: 0.65rem;
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
  }

  .install-panel a:hover {
    text-decoration: underline;
  }

  .catalog-content {
    min-width: 0;
  }

  .resource-group + .resource-group {
    margin-top: 5rem;
    padding-top: 5rem;
    border-top: 1px solid var(--line);
  }

  .section-heading {
    margin-bottom: 1.85rem;
  }

  .section-heading h2 {
    margin-top: 0;
  }

  .resource-grid {
    display: grid;
    gap: 1.1rem;
  }

  .resource-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--panel);
    box-shadow: 0 10px 28px rgba(16, 24, 32, 0.04);
  }

  .resource-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.38rem;
    letter-spacing: -0.03em;
  }

  .resource-summary p,
  .resource-details p,
  .resource-details li {
    color: var(--muted);
    line-height: 1.65;
  }

  .path {
    margin: 0 0 0.4rem;
  }

  .path code {
    color: var(--accent);
    font-weight: 800;
  }

  .summary {
    margin: 0;
  }

  .best {
    margin-top: 1rem;
  }

  h4 {
    margin: 0 0 0.6rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .resource-details {
    display: grid;
    gap: 1rem;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .link-list {
    list-style: disc;
  }

  .link-list a {
    color: var(--ink);
    text-decoration: none;
  }

  .link-list a:hover {
    text-decoration: underline;
  }

  .checklist-wrap {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1fr);
    gap: 2rem;
  }

  .checklist {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.75;
  }

  .checklist strong {
    color: var(--ink);
  }

  @media (max-width: 1040px) {
    .hero-grid,
    .install-grid,
    .checklist-wrap {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .hero {
      padding-top: 4rem;
    }

    .resource-card,
    .links-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
