---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createAwesomeRepoSearchUrl, installableSkill, sections, siteLinks } from '../data/resources';
import { slugify } from '../lib/slugify.js';

const totalResources = sections.reduce((total, section) => total + section.resources.length, 0);
const catalogItems = sections.flatMap((section) => section.resources);
const catalogSchema = {
  '@type': 'ItemList',
  '@id': `${siteLinks.site}/#catalog`,
  name: 'AI steering file catalog',
  description: 'A curated catalog of steering files and agent instruction files for AI coding agents.',
  itemListElement: catalogItems.map((resource, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'CreativeWork',
      name: resource.name,
      url: `${siteLinks.site}/#${slugify(resource.name)}`,
      description: resource.summary
    }
  }))
};
---

<BaseLayout
  title="AI Steering Files - choose repo context for coding agents"
  description="Browse practical AGENTS.md, PRODUCT.md, TECH.md, and tool-specific instruction file patterns for AI coding agents, with examples and references."
  structuredData={[catalogSchema]}
>
  <main id="main-content">
    <section class="page-header">
      <div class="container page-header-grid">
        <div>
          <p class="section-label">Repository context</p>
          <h1>AI Steering Files catalogs repo context for coding agents.</h1>
          <p class="lede">
            Browse practical patterns for <code>AGENTS.md</code>, <code>PRODUCT.md</code>, <code>TECH.md</code>, and tool-specific files. Each entry shows when to add it, what to include, and examples worth studying.
          </p>
          <div class="actions">
            <a class="button" href="#catalog">Browse catalog</a>
            <a class="button secondary" href="#install-skill">Install skill</a>
            <a class="button secondary" href="/llms.txt">Text version</a>
          </div>
        </div>
        <aside class="info-panel" aria-labelledby="quick-start-heading">
          <h2 id="quick-start-heading">Use this index when</h2>
          <ul class="plain-list">
            <li>Start with agent-agnostic files for rules every coding assistant should share.</li>
            <li>Add tool-specific files when an assistant needs its own syntax, memory, or scoped rules.</li>
            <li>Keep each file tied to real commands, constraints, and examples from the repo.</li>
          </ul>
        </aside>
      </div>
    </section>

    <section id="install-skill" class="section install-section">
      <div class="container install-grid">
        <div>
          <p class="section-label">Reusable skill</p>
          <h2>Install the catalog as an agent skill.</h2>
          <p class="section-lede">
            The <code>{installableSkill.name}</code> skill gives agents a compact workflow for choosing, writing, and auditing repo context files in any project.
          </p>
          <a class="button secondary" href={siteLinks.skill}>View skill source</a>
        </div>

        <div class="install-panel" aria-label="Skill installation commands">
          <div class="install-command">
            <div class="install-command-header">
              <h3>Skills CLI</h3>
              <button
                class="copy-command"
                type="button"
                data-copy-target="skills-cli-command"
                aria-label="Copy Skills CLI install command"
                aria-describedby="skills-cli-copy-status"
                hidden
              >
                Copy
              </button>
            </div>
            <pre id="skills-cli-command" tabindex="0" aria-label="Skills CLI install command"><code>{installableSkill.skillsCliCommand}</code></pre>
            <p class="copy-status" id="skills-cli-copy-status" aria-live="polite"></p>
            <a href={siteLinks.skillsCli}>Skills CLI docs</a>
          </div>

          <div class="install-command">
            <div class="install-command-header">
              <h3>GitHub CLI</h3>
              <button
                class="copy-command"
                type="button"
                data-copy-target="github-cli-command"
                aria-label="Copy GitHub CLI install command"
                aria-describedby="github-cli-copy-status"
                hidden
              >
                Copy
              </button>
            </div>
            <pre id="github-cli-command" tabindex="0" aria-label="GitHub CLI install command"><code>{installableSkill.githubCliCommand}</code></pre>
            <p class="copy-status" id="github-cli-copy-status" aria-live="polite"></p>
            <a href={siteLinks.ghSkill}>gh skill install docs</a>
          </div>
        </div>
      </div>
    </section>

    <section id="catalog" class="section">
      <div class="container catalog-layout">
        <aside class="catalog-index" aria-labelledby="catalog-index-heading">
          <h2 id="catalog-index-heading">Catalog</h2>
          <p>{totalResources} file types across {sections.length} groups.</p>
          <nav aria-label="Catalog sections">
            <ul>
              {sections.map((section) => (
                <li>
                  <a href={`#${section.slug}`}>
                    <span>{section.title}</span>
                    <span class="catalog-count">{section.resources.length}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>

        <div class="catalog-content">
          <div class="catalog-heading">
            <h2>Steering file catalog</h2>
            <p class="section-lede">
              Each entry keeps the same structure: purpose, best use cases, required contents, reference links, and examples.
            </p>
          </div>

          {sections.map((section) => (
            <section class="resource-group" id={section.slug} aria-labelledby={`${section.slug}-heading`}>
              <header class="resource-group-header">
                <div>
                  <h3 id={`${section.slug}-heading`}>{section.title}</h3>
                  <p>{section.intro}</p>
                </div>
                <span>{section.resources.length} files</span>
              </header>

              <div class="resource-list">
                {section.resources.map((resource) => {
                  const resourceId = slugify(resource.name);
                  const awesomeRepoSearchHref = section.showAwesomeRepoSearch
                    ? createAwesomeRepoSearchUrl(resource.path)
                    : null;

                  return (
                    <article class="resource-card" id={resourceId} aria-labelledby={`${resourceId}-title`}>
                      <div class="resource-summary">
                        <p class="path"><code>{resource.path}</code></p>
                        <h4 id={`${resourceId}-title`}>{resource.name}</h4>
                        <p class="summary">{resource.summary}</p>
                        <div class="resource-field">
                          <p class="field-label">Use it for</p>
                          <p class="use-list">{resource.useItFor.join(' · ')}</p>
                        </div>
                      </div>

                      <div class="resource-details">
                        <div>
                          <p class="field-label">Should contain</p>
                          <ul>
                            {resource.shouldContain.map((item) => <li>{item}</li>)}
                          </ul>
                        </div>
                        <div>
                          <p class="field-label">Useful resources</p>
                          <ul class="link-list">
                            {resource.usefulResources.map((link) => (
                              <li><a href={link.href}>{link.label}</a></li>
                            ))}
                          </ul>
                        </div>
                        <div>
                          <p class="field-label">Great examples</p>
                          <ul class="link-list">
                            {resource.greatExamples.map((link) => (
                              <li><a href={link.href}>{link.label}</a></li>
                            ))}
                            {awesomeRepoSearchHref && (
                              <li>
                                <a
                                  href={awesomeRepoSearchHref}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  aria-label={`See more ${resource.path} examples on Awesome`}
                                >
                                  see more
                                </a>
                              </li>
                            )}
                          </ul>
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section id="checklist" class="section">
      <div class="container split-layout">
        <div>
          <p class="section-label">Writing checklist</p>
          <h2>Useful steering files are short, specific, and grounded in the repo.</h2>
          <p class="section-lede">
            Each item should make agent behavior easier to verify while it is editing.
          </p>
        </div>
        <ol class="checklist content-panel">
          <li><strong>Define the file's job.</strong> Start with the scope and the intended reader.</li>
          <li><strong>Prefer commands over vague guidance.</strong> Include exact install, test, lint, build, and deploy commands.</li>
          <li><strong>Point to patterns worth copying.</strong> Name files and modules that show the preferred approach.</li>
          <li><strong>Write down the boundaries.</strong> Spell out security, data, accessibility, performance, and product constraints.</li>
          <li><strong>Keep one source of truth.</strong> Edit the data map once, then render the site and README from it.</li>
          <li><strong>Review after real agent work.</strong> Update the files when agents repeatedly ask the same question or make the same mistake.</li>
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  const copyButtons = document.querySelectorAll('[data-copy-target]');

  const selectCommandText = (target) => {
    const selection = window.getSelection();
    const range = document.createRange();
    range.selectNodeContents(target);
    selection?.removeAllRanges();
    selection?.addRange(range);
    try {
      target.focus({ preventScroll: true });
    } catch {
      target.focus();
    }
  };

  const copyText = async (text) => {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      return true;
    }

    return false;
  };

  copyButtons.forEach((button) => {
    button.hidden = false;

    button.addEventListener('click', async () => {
      const targetId = button.getAttribute('data-copy-target');
      const target = targetId ? document.getElementById(targetId) : null;
      const status = button.getAttribute('aria-describedby')
        ? document.getElementById(button.getAttribute('aria-describedby'))
        : null;

      if (!target) {
        return;
      }

      const originalLabel = button.dataset.label || button.textContent || 'Copy';
      button.dataset.label = originalLabel;
      button.disabled = true;
      button.textContent = 'Copying';
      button.dataset.state = 'pending';

      try {
        const copied = await copyText(target.textContent.trim());

        if (!copied) {
          throw new Error('Clipboard command unavailable.');
        }

        button.textContent = 'Copied';
        button.dataset.state = 'success';
        if (status) {
          status.textContent = 'Command copied.';
        }
      } catch {
        selectCommandText(target);
        button.textContent = 'Selected';
        button.dataset.state = 'fallback';
        if (status) {
          status.textContent = 'Copy failed. Command text selected for manual copy.';
        }
      } finally {
        window.setTimeout(() => {
          button.disabled = false;
          button.textContent = originalLabel;
          button.dataset.state = 'idle';
          if (status) {
            status.textContent = '';
          }
        }, 2200);
      }
    });
  });
</script>

<style>
  .catalog-layout {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .catalog-index {
    position: sticky;
    top: 1rem;
  }

  .catalog-index h2 {
    margin: 0;
    font-size: 1rem;
    letter-spacing: 0;
  }

  .catalog-index p {
    margin: 0.35rem 0 0.85rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .catalog-index ul {
    display: grid;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .catalog-index a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    min-height: 44px;
    border-radius: var(--radius-sm);
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 600;
    padding: 0.55rem 0.6rem;
    text-decoration: none;
  }

  .catalog-index a:hover {
    background: var(--surface-muted);
    color: var(--ink);
  }

  .catalog-count {
    display: inline-flex;
    min-width: 1.65rem;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--subtle);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .install-section {
    background: var(--surface-muted);
  }

  .install-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(340px, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .install-grid > *,
  .install-panel > * {
    min-width: 0;
  }

  .install-panel {
    display: grid;
    gap: 1rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .install-command {
    display: grid;
    gap: 0.65rem;
  }

  .install-command-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
  }

  .install-panel h3 {
    margin: 0;
    font-size: 1rem;
  }

  .install-panel pre {
    overflow-x: hidden;
    margin: 0;
    max-width: 100%;
    padding: 0.95rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--ink);
    color: var(--accent-ink);
    font-size: 0.88rem;
    line-height: 1.55;
    overflow-wrap: anywhere;
    white-space: pre-wrap;
  }

  .install-panel pre code {
    background: transparent;
    color: inherit;
    font-size: inherit;
    font-weight: 600;
    padding: 0;
    white-space: inherit;
  }

  .install-panel pre:focus-visible {
    outline: 3px solid var(--focus);
    outline-offset: 3px;
  }

  .copy-command {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 4.9rem;
    min-height: 44px;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--ink);
    cursor: pointer;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    transition:
      background-color 180ms ease-out,
      border-color 180ms ease-out,
      color 180ms ease-out;
  }

  .copy-command:hover {
    border-color: var(--line-strong);
    background: var(--surface-muted);
  }

  .copy-command:disabled {
    cursor: default;
  }

  .copy-command[data-state="success"] {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent-hover);
  }

  .copy-command[data-state="fallback"] {
    border-color: var(--line-strong);
    background: var(--surface-muted);
  }

  .copy-status {
    margin: -0.25rem 0 0;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .copy-status:empty {
    display: none;
  }

  .install-panel a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin-top: 0;
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
  }

  .install-panel a:hover {
    text-decoration: underline;
  }

  .catalog-content {
    min-width: 0;
  }

  .catalog-heading {
    margin-bottom: 2rem;
  }

  .catalog-heading .section-lede {
    max-width: var(--measure);
  }

  .resource-group + .resource-group {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--line);
  }

  .resource-group {
    scroll-margin-top: 1rem;
  }

  .resource-group-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .resource-group-header h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }

  .resource-group-header p {
    max-width: var(--measure);
    margin: 0.45rem 0 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .resource-group-header span {
    flex: 0 0 auto;
    color: var(--subtle);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .resource-list {
    display: grid;
    gap: 0.85rem;
  }

  .resource-card {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: 1.25rem;
    padding: 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: border-color 180ms ease-out, background-color 180ms ease-out;
  }

  .resource-card:hover {
    border-color: var(--line-strong);
    background: var(--surface);
  }

  .resource-card h4 {
    margin: 0 0 0.5rem;
    font-size: 1.18rem;
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  .resource-summary p,
  .resource-details p,
  .resource-details li {
    color: var(--muted);
    line-height: 1.65;
  }

  .path {
    margin: 0 0 0.4rem;
  }

  .summary {
    margin: 0;
  }

  .resource-field {
    margin-top: 1rem;
  }

  .field-label {
    margin: 0 0 0.35rem;
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .use-list {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .resource-details {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr) minmax(0, 0.9fr);
    gap: 1rem;
  }

  .resource-details ul,
  .link-list {
    margin: 0;
    padding-left: 1.1rem;
  }

  .link-list a {
    color: var(--ink);
    text-decoration-color: var(--line-strong);
  }

  .link-list a:hover {
    text-decoration-color: var(--ink);
  }

  .checklist {
    margin: 0;
    max-width: var(--measure);
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.75;
  }

  .checklist strong {
    color: var(--ink);
  }

  @media (max-width: 1040px) {
    .install-grid,
    .catalog-layout {
      grid-template-columns: 1fr;
    }

    .catalog-index {
      position: static;
    }

    .catalog-index ul {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }

  @media (max-width: 760px) {
    .resource-card,
    .resource-details {
      grid-template-columns: 1fr;
    }

    .resource-group-header {
      display: block;
    }

    .resource-group-header span {
      display: inline-block;
      margin-top: 0.7rem;
    }

    .link-list a {
      display: inline-flex;
      align-items: center;
      min-width: 44px;
      min-height: 44px;
    }
  }

  @media (pointer: coarse) {
    .link-list a {
      display: inline-flex;
      align-items: center;
      min-width: 44px;
      min-height: 44px;
    }
  }
</style>
