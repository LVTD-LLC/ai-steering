---
import BaseLayout from '../layouts/BaseLayout.astro';
import { installableSkill, sections, siteLinks } from '../data/resources';
import { slugify } from '../lib/slugify.js';

const totalResources = sections.reduce((total, section) => total + section.resources.length, 0);
---

<BaseLayout title="AI Steering Files - repo context for coding agents" description="A shared guide to the files that teach AI agents how to work in this repo.">
  <main id="main-content">
    <section class="page-header">
      <div class="container page-header-grid">
        <div>
          <p class="section-label">Repository guidance index</p>
          <h1>Find the steering file your repo needs.</h1>
          <p class="lede">
            A compact reference for the repo context files that help AI coding agents follow local rules, use the right commands, and make better edits.
          </p>
          <div class="actions">
            <a class="button" href="#install-skill">Install the skill</a>
            <a class="button secondary" href="#catalog">Browse catalog</a>
            <a class="button secondary" href={siteLinks.readme}>Open the README</a>
          </div>
        </div>
        <aside class="info-panel" aria-labelledby="quick-start-heading">
          <h2 id="quick-start-heading">Use this index when</h2>
          <ul class="plain-list">
            <li>Start with the agent-agnostic files when you need repo rules that apply everywhere.</li>
            <li>Add agent-specific files only when a tool needs its own syntax or workflow hints.</li>
            <li>Check examples before copying patterns into another repository.</li>
          </ul>
        </aside>
      </div>
    </section>

    <section id="install-skill" class="section install-section">
      <div class="container install-grid">
        <div>
          <p class="section-label">Reusable skill</p>
          <h2>Install the catalog as an agent skill.</h2>
          <p class="section-lede">
            The <code>{installableSkill.name}</code> skill gives agents a compact workflow for choosing, writing, and auditing repo context files in any project.
          </p>
          <a class="button secondary" href={siteLinks.skill}>View skill source</a>
        </div>

        <div class="install-panel" aria-label="Skill installation commands">
          <div>
            <h3>Skills CLI</h3>
            <pre><code>{installableSkill.skillsCliCommand}</code></pre>
            <a href={siteLinks.skillsCli}>Skills CLI docs</a>
          </div>

          <div>
            <h3>GitHub CLI</h3>
            <pre><code>{installableSkill.githubCliCommand}</code></pre>
            <a href={siteLinks.ghSkill}>gh skill install docs</a>
          </div>
        </div>
      </div>
    </section>

    <section id="catalog" class="section">
      <div class="container catalog-layout">
        <aside class="catalog-index" aria-labelledby="catalog-index-heading">
          <h2 id="catalog-index-heading">Catalog</h2>
          <p>{totalResources} file types across {sections.length} groups.</p>
          <nav aria-label="Catalog sections">
            <ul>
              {sections.map((section) => (
                <li>
                  <a href={`#${section.slug}`}>
                    <span>{section.title}</span>
                    <span class="catalog-count">{section.resources.length}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>

        <div class="catalog-content">
          <div class="section-heading catalog-heading">
            <h2>Steering file catalog</h2>
            <p class="section-lede">
              Each entry keeps the same structure: purpose, best use cases, required contents, reference links, and examples.
            </p>
          </div>

          {sections.map((section) => (
            <section class="resource-group" id={section.slug} aria-labelledby={`${section.slug}-heading`}>
              <header class="resource-group-header">
                <div>
                  <h3 id={`${section.slug}-heading`}>{section.title}</h3>
                  <p>{section.intro}</p>
                </div>
                <span>{section.resources.length} files</span>
              </header>

              <div class="resource-list">
                {section.resources.map((resource) => {
                  const resourceId = slugify(resource.name);

                  return (
                    <article class="resource-card" id={resourceId} aria-labelledby={`${resourceId}-title`}>
                      <div class="resource-summary">
                        <p class="path"><code>{resource.path}</code></p>
                        <h4 id={`${resourceId}-title`}>{resource.name}</h4>
                        <p class="summary">{resource.summary}</p>
                        <div class="resource-field">
                          <p class="field-label">Use it for</p>
                          <p class="use-list">{resource.useItFor.join(' · ')}</p>
                        </div>
                      </div>

                      <div class="resource-details">
                        <div>
                          <p class="field-label">Should contain</p>
                          <ul>
                            {resource.shouldContain.map((item) => <li>{item}</li>)}
                          </ul>
                        </div>
                        <div>
                          <p class="field-label">Useful resources</p>
                          <ul class="link-list">
                            {resource.usefulResources.map((link) => (
                              <li><a href={link.href}>{link.label}</a></li>
                            ))}
                          </ul>
                        </div>
                        <div>
                          <p class="field-label">Great examples</p>
                          <ul class="link-list">
                            {resource.greatExamples.map((link) => (
                              <li><a href={link.href}>{link.label}</a></li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section id="checklist" class="section">
      <div class="container split-layout">
        <div>
          <p class="section-label">Writing checklist</p>
          <h2>Write steering files agents can act on.</h2>
          <p class="section-lede">
            The best guidance is short, repo-specific, and easy to verify while an agent is editing.
          </p>
        </div>
        <ol class="checklist content-panel">
          <li><strong>Say what the file controls.</strong> Start with the scope and the intended reader.</li>
          <li><strong>Prefer commands over vibes.</strong> Include exact install, test, lint, build, and deploy commands.</li>
          <li><strong>Name the good examples.</strong> Point agents to files and modules that show the preferred pattern.</li>
          <li><strong>Document constraints.</strong> Spell out security, data, accessibility, performance, and product boundaries.</li>
          <li><strong>Keep the source shared.</strong> Edit the data map once, then render the site and README from it.</li>
          <li><strong>Review after real agent work.</strong> Update the files when agents repeatedly ask the same question or make the same mistake.</li>
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .catalog-layout {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .catalog-index {
    position: sticky;
    top: 4.7rem;
  }

  .catalog-index h2 {
    margin: 0;
    font-size: 1rem;
    letter-spacing: 0;
  }

  .catalog-index p {
    margin: 0.35rem 0 0.85rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .catalog-index ul {
    display: grid;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .catalog-index a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    border-radius: var(--radius-sm);
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 650;
    padding: 0.55rem 0.6rem;
    text-decoration: none;
  }

  .catalog-index a:hover {
    background: var(--surface-muted);
    color: var(--ink);
  }

  .catalog-count {
    display: inline-flex;
    min-width: 1.65rem;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--subtle);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .install-section {
    background: var(--surface-muted);
  }

  .install-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(340px, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .install-grid > *,
  .install-panel > * {
    min-width: 0;
  }

  .install-panel {
    display: grid;
    gap: 1rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .install-panel h3 {
    margin: 0 0 0.55rem;
    font-size: 1rem;
  }

  .install-panel pre {
    overflow-x: auto;
    margin: 0;
    max-width: 100%;
    padding: 0.95rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--ink);
    color: var(--accent-ink);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .install-panel pre code {
    background: transparent;
    color: inherit;
    font-size: inherit;
    font-weight: 600;
    padding: 0;
  }

  .install-panel a {
    display: inline-block;
    margin-top: 0.65rem;
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
  }

  .install-panel a:hover {
    text-decoration: underline;
  }

  .catalog-content {
    min-width: 0;
  }

  .catalog-heading {
    margin-bottom: 2rem;
  }

  .resource-group + .resource-group {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--line);
  }

  .resource-group {
    scroll-margin-top: 5.5rem;
  }

  .resource-group-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .resource-group-header h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }

  .resource-group-header p {
    max-width: 760px;
    margin: 0.45rem 0 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .resource-group-header span {
    flex: 0 0 auto;
    color: var(--subtle);
    font-size: 0.9rem;
    font-weight: 650;
  }

  .resource-list {
    display: grid;
    gap: 0.85rem;
  }

  .resource-card {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: 1.25rem;
    padding: 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: border-color 180ms ease-out, background-color 180ms ease-out;
  }

  .resource-card:hover {
    border-color: var(--line-strong);
    background: oklch(100% 0 0);
  }

  .resource-card h4 {
    margin: 0 0 0.5rem;
    font-size: 1.18rem;
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  .resource-summary p,
  .resource-details p,
  .resource-details li {
    color: var(--muted);
    line-height: 1.65;
  }

  .path {
    margin: 0 0 0.4rem;
  }

  .summary {
    margin: 0;
  }

  .resource-field {
    margin-top: 1rem;
  }

  .field-label {
    margin: 0 0 0.35rem;
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 720;
  }

  .use-list {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .resource-details {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr) minmax(0, 0.9fr);
    gap: 1rem;
  }

  .resource-details ul,
  .link-list {
    margin: 0;
    padding-left: 1.1rem;
  }

  .link-list a {
    color: var(--ink);
    text-decoration-color: var(--line-strong);
  }

  .link-list a:hover {
    text-decoration-color: var(--ink);
  }

  .checklist {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.75;
  }

  .checklist strong {
    color: var(--ink);
  }

  @media (max-width: 1040px) {
    .install-grid,
    .catalog-layout {
      grid-template-columns: 1fr;
    }

    .catalog-index {
      position: static;
    }

    .catalog-index ul {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }

  @media (max-width: 760px) {
    .resource-card,
    .resource-details {
      grid-template-columns: 1fr;
    }

    .resource-group-header {
      display: block;
    }

    .resource-group-header span {
      display: inline-block;
      margin-top: 0.7rem;
    }
  }
</style>
