---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sections, siteLinks } from '../data/resources';
import { slugify } from '../lib/slugify.js';
---

<BaseLayout title="AI Steering Files - repo context for coding agents" description="A shared guide to the files that teach AI agents how to work in this repo.">
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Shared source map</p>
          <h1>AI steering files for real projects.</h1>
          <p class="lede">
            This site and the README are rendered from the same content map, so the guidance stays in sync as the repo grows.
            Use it to see which files matter, what each one should contain, and where to add new context without making the tree noisy.
          </p>
          <div class="actions">
            <a class="button" href="#catalog">Browse the catalog</a>
            <a class="button secondary" href={siteLinks.readme}>Read the README</a>
            <a class="button secondary" href={siteLinks.repo}>Open the repo</a>
          </div>
        </div>
        <p class="source-note">
          Shared source: <a href={siteLinks.source}><code>src/data/steering-data.js</code></a>
        </p>
      </div>
    </section>

    <section id="catalog" class="section">
      <div class="container catalog-shell">
        <aside class="toc-rail" aria-label="Table of contents">
          <div class="toc-head">
            <p class="eyebrow">TOC</p>
            <h2>Jump to a section or a file.</h2>
          </div>
          <nav class="toc-list">
            {sections.map((section) => (
              <div class="toc-group">
                <a class="toc-section" href={`#${section.slug}`}>{section.title}</a>
                {section.resources.map((resource) => (
                  <a class="toc-file" href={`#${slugify(resource.name)}`}>
                    <code>{resource.path}</code>
                  </a>
                ))}
              </div>
            ))}
          </nav>
          <div class="toc-links">
            <a href={siteLinks.readme}>README</a>
            <a href={siteLinks.repo}>GitHub repo</a>
          </div>
        </aside>

        <div class="catalog-content">
          {sections.map((section) => (
            <section class="resource-group" id={section.slug}>
              <div class="section-heading">
                <p class="eyebrow">{section.title}</p>
                <h2>{section.title}</h2>
                <p class="section-lede">{section.intro}</p>
              </div>

              <div class="resource-grid">
                {section.resources.map((resource) => (
                  <article class="resource-card" id={slugify(resource.name)}>
                    <div class="resource-summary">
                      <p class="path"><code>{resource.path}</code></p>
                      <h3>{resource.name}</h3>
                      <p class="summary">{resource.summary}</p>
                      <p class="best"><strong>Use it for:</strong> {resource.useItFor.join(', ')}</p>
                    </div>

                    <div class="resource-details">
                      <div>
                        <h4>Should contain</h4>
                        <ul>
                          {resource.shouldContain.map((item) => <li>{item}</li>)}
                        </ul>
                      </div>

                      <div class="links-grid">
                        <div>
                          <h4>Useful resources</h4>
                          <ul class="link-list">
                            {resource.usefulResources.map((link) => (
                              <li><a href={link.href}>{link.label}</a></li>
                            ))}
                          </ul>
                        </div>

                        <div>
                          <h4>Great examples</h4>
                          <ul class="link-list">
                            {resource.greatExamples.map((link) => (
                              <li><a href={link.href}>{link.label}</a></li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section id="checklist" class="section">
      <div class="container checklist-wrap">
        <div>
          <p class="eyebrow">Writing checklist</p>
          <h2>Good steering files are short, specific, and grounded in the repo.</h2>
        </div>
        <ol class="checklist">
          <li><strong>Say what the file controls.</strong> Start with the scope and the intended reader.</li>
          <li><strong>Prefer commands over vibes.</strong> Include exact install, test, lint, build, and deploy commands.</li>
          <li><strong>Name the good examples.</strong> Point agents to files and modules that show the preferred pattern.</li>
          <li><strong>Document constraints.</strong> Spell out security, data, accessibility, performance, and product boundaries.</li>
          <li><strong>Keep the source shared.</strong> Edit the data map once, then render the site and README from it.</li>
          <li><strong>Review after real agent work.</strong> Update the files when agents repeatedly ask the same question or make the same mistake.</li>
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0 3.5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 320px);
    gap: 2rem;
    align-items: start;
  }

  h1 {
    margin: 0;
    max-width: 880px;
    font-size: clamp(3.2rem, 8vw, 6.8rem);
    line-height: 0.9;
  }

  .lede {
    max-width: 760px;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.6vw, 1.22rem);
    line-height: 1.68;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  .source-note {
    margin: 0;
    padding-top: 0.4rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .source-note a {
    text-decoration-thickness: 2px;
    text-underline-offset: 0.18em;
  }

  .catalog-shell {
    display: grid;
    grid-template-columns: minmax(280px, 320px) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .toc-rail {
    position: sticky;
    top: 5.75rem;
    max-height: calc(100vh - 7rem);
    overflow: auto;
    padding-right: 0.4rem;
  }

  .toc-head h2 {
    margin: 0 0 0.75rem;
    font-size: 1.2rem;
    line-height: 1.1;
  }

  .toc-list {
    display: grid;
    gap: 1rem;
  }

  .toc-group {
    display: grid;
    gap: 0.35rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--line);
  }

  .toc-group:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .toc-section {
    color: var(--ink);
    font-weight: 900;
    text-decoration: none;
  }

  .toc-file {
    color: var(--muted);
    text-decoration: none;
    line-height: 1.45;
  }

  .toc-file code {
    color: var(--accent);
    font-weight: 800;
  }

  .toc-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .toc-links a {
    color: var(--ink);
    font-weight: 800;
    text-decoration: none;
  }

  .catalog-content {
    min-width: 0;
  }

  .resource-group + .resource-group {
    margin-top: 4.2rem;
  }

  .section-heading {
    margin-bottom: 1.6rem;
  }

  .section-heading h2 {
    margin-top: 0;
  }

  .resource-grid {
    display: grid;
    gap: 1rem;
  }

  .resource-card {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
    gap: 1.4rem;
    padding: 1.35rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .resource-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.45rem;
  }

  .resource-summary p,
  .resource-details p,
  .resource-details li {
    color: var(--muted);
    line-height: 1.65;
  }

  .path {
    margin: 0 0 0.4rem;
  }

  .path code {
    color: var(--accent);
    font-weight: 800;
  }

  .summary {
    margin: 0;
  }

  .best {
    margin-top: 1rem;
  }

  h4 {
    margin: 0 0 0.6rem;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .resource-details {
    display: grid;
    gap: 1rem;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .link-list {
    list-style: disc;
  }

  .link-list a {
    color: var(--ink);
    text-decoration: none;
  }

  .link-list a:hover,
  .toc-section:hover,
  .toc-file:hover,
  .toc-links a:hover {
    text-decoration: underline;
  }

  .checklist-wrap {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1fr);
    gap: 2rem;
  }

  .checklist {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.75;
  }

  .checklist strong {
    color: var(--ink);
  }

  @media (max-width: 1040px) {
    .hero-grid,
    .catalog-shell,
    .checklist-wrap {
      grid-template-columns: 1fr;
    }

    .toc-rail {
      position: static;
      max-height: none;
      padding-right: 0;
      padding-bottom: 1.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--line);
    }
  }

  @media (max-width: 760px) {
    .hero {
      padding-top: 4rem;
    }

    .resource-card,
    .links-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
