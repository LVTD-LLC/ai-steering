---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found - AI Steering Files"
  description="The requested AI Steering Files page could not be found."
  canonicalPath={false}
  robots="noindex, follow"
>
  <main id="main-content">
    <section class="not-found">
      <div class="container">
        <p class="eyebrow">404</p>
        <h1>Page not found.</h1>
        <p class="lede">The page may have moved, or the URL may be incorrect.</p>
        <a class="button" href="/">Return home</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .not-found {
    min-height: 62vh;
    padding: 5.5rem 0 4rem;
    display: grid;
    align-items: center;
  }

  h1 {
    margin: 0;
    max-width: 780px;
    font-size: 4.75rem;
    line-height: 0.94;
    text-wrap: balance;
  }

  .lede {
    max-width: 560px;
    margin: 1rem 0 1.7rem;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.65;
  }

  @media (max-width: 760px) {
    h1 {
      font-size: 3rem;
    }
  }
</style>
